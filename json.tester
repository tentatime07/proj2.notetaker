import json

names = ["Alice", "Bob", "Charlie"]

with open("names.json", "w") as file:
    json.dump(names, file)

print(file)

with open("names.json", "r") as file:
    data = json.load(file)

print(data[2])

new_char = "tommy"

data.append(new_char)

with open("names.json", "w") as file:
    json.dump(data,file)

with open("names.json", "r") as file:
    f = json.load(file)

print(f[3])
print(data[3])